---
import Layout from '../layouts/Layout.astro';
---

<Layout title="KAAP Project Aanleveren">
    <div class="space-y-10 reveal active pt-4">
        <div class="max-w-7xl mx-auto">
            <a href="/" class="inline-flex items-center gap-2 text-kaap-text-gray hover:text-kaap-pink font-semibold transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                </svg>
                Terug naar overzicht
            </a>
        </div>
        <div class="text-center space-y-4 -mt-4">
            <div class="inline-block px-4 py-1.5 rounded-full bg-white border border-gray-200 text-sm font-semibold text-kaap-purple mb-2 shadow-sm">
                Nieuw Project Aanmelden
            </div>
            <h1 class="text-4xl md:text-5xl font-heading font-bold text-kaap-gray leading-tight">
                Deel jouw <span class="text-kaap-pink">KAAP Project</span>
            </h1>
            <p class="text-kaap-text-gray text-lg max-w-2xl mx-auto leading-relaxed">
                Vul dit formulier in om een nieuw project gestructureerd aan te leveren voor op de KAAP website.
            </p>
        </div>

        <form id="submissionForm" class="bg-white p-8 md:p-10 rounded-3xl shadow-xl shadow-gray-200/50 border border-gray-100 space-y-8 relative overflow-hidden">
            <!-- Top shimmer effect -->
            <div class="absolute top-0 left-0 w-full h-1 bg-kaap-gradient"></div>

            <div id="formFeedback" class="hidden p-4 rounded-xl text-center font-semibold mb-4 transition-all"></div>

            <!-- Projectnaam -->
            <div class="space-y-2">
                <label for="title" class="block font-heading font-semibold text-kaap-gray text-lg">Projectnaam <span class="text-kaap-pink">*</span></label>
                <p class="text-sm text-kaap-text-gray mb-2">Officiële, korte titel van het project.</p>
                <input type="text" id="title" name="title" required
                    class="w-full px-5 py-4 rounded-xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-kaap-pink/50 focus:ring-4 focus:ring-kaap-pink/10 outline-none transition-all duration-300 font-medium placeholder-gray-400"
                    placeholder="Bijv: KAAP Intelligent Energy Solutions..." />
            </div>

            <!-- Korte Samenvatting -->
            <div class="space-y-2">
                <label for="summary" class="block font-heading font-semibold text-kaap-gray text-lg">Korte Samenvatting <span class="text-kaap-pink">*</span></label>
                <p class="text-sm text-kaap-text-gray mb-2">Een één- of tweezinner als introductie.</p>
                <input type="text" id="summary" name="summary" required
                    class="w-full px-5 py-4 rounded-xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-kaap-pink/50 focus:ring-4 focus:ring-kaap-pink/10 outline-none transition-all duration-300 font-medium placeholder-gray-400"
                    placeholder="Dit project richt zich op..." />
            </div>

             <!-- Uitgebreide beschrijving -->
             <div class="space-y-2">
                <div class="flex items-center justify-between">
                    <label for="description" class="block font-heading font-semibold text-kaap-gray text-lg">Uitgebreide Beschrijving <span class="text-kaap-pink">*</span></label>
                    <button type="button" id="micButton" class="text-kaap-gray hover:text-kaap-pink transition-colors p-2 rounded-full hover:bg-gray-100 hidden group-focus-within:block" title="Spreek in">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z" />
                        </svg>
                    </button>
                </div>
                <p class="text-sm text-kaap-text-gray mb-2">Waarom, voor wie en wat zijn de doelen?</p>
                <div class="relative">
                    <textarea id="description" name="description" rows="5" required
                        class="w-full px-5 py-4 rounded-xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-kaap-pink/50 focus:ring-4 focus:ring-kaap-pink/10 outline-none transition-all duration-300 font-medium placeholder-gray-400 resize-none"
                        placeholder="Typ hier de volledige projectbeschrijving..."></textarea>
                    <div id="micStatus" class="absolute top-2 right-2 hidden">
                        <span class="flex h-3 w-3">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-3 w-3 bg-red-500"></span>
                        </span>
                    </div>
                </div>
            </div>

            <!-- Transitiethema -->
            <div class="space-y-3">
                <label class="block font-heading font-semibold text-kaap-gray text-lg">Transitiethema <span class="text-kaap-pink">*</span></label>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                    <label class="cursor-pointer relative">
                        <input type="radio" name="transitionTheme" value="Water" class="peer sr-only" required>
                        <div class="p-3 rounded-xl bg-gray-50 border-2 border-transparent peer-checked:border-blue-500 peer-checked:bg-blue-50 hover:bg-gray-100 transition-all text-center font-medium text-kaap-gray">
                            💧 Water
                        </div>
                    </label>
                    <label class="cursor-pointer relative">
                        <input type="radio" name="transitionTheme" value="Voedsel" class="peer sr-only">
                        <div class="p-3 rounded-xl bg-gray-50 border-2 border-transparent peer-checked:border-green-500 peer-checked:bg-green-50 hover:bg-gray-100 transition-all text-center font-medium text-kaap-gray">
                            🍎 Voedsel
                        </div>
                    </label>
                    <label class="cursor-pointer relative">
                        <input type="radio" name="transitionTheme" value="Energie" class="peer sr-only">
                        <div class="p-3 rounded-xl bg-gray-50 border-2 border-transparent peer-checked:border-yellow-500 peer-checked:bg-yellow-50 hover:bg-gray-100 transition-all text-center font-medium text-kaap-gray">
                            ⚡ Energie
                        </div>
                    </label>
                    <label class="cursor-pointer relative">
                        <input type="radio" name="transitionTheme" value="Meerdere/Anders" class="peer sr-only">
                        <div class="p-3 rounded-xl bg-gray-50 border-2 border-transparent peer-checked:border-kaap-purple peer-checked:bg-purple-50 hover:bg-gray-100 transition-all text-center font-medium text-kaap-gray">
                            🌍 Anders / Mix
                        </div>
                    </label>
                </div>
            </div>

            <!-- Betrokken Partners -->
            <div class="space-y-2">
                <label for="partners" class="block font-heading font-semibold text-kaap-gray text-lg">Betrokken Partners</label>
                <p class="text-sm text-kaap-text-gray mb-2">Welke organisaties of stakeholders werken mee?</p>
                <input type="text" id="partners" name="partners"
                    class="w-full px-5 py-4 rounded-xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-kaap-pink/50 focus:ring-4 focus:ring-kaap-pink/10 outline-none transition-all duration-300 font-medium placeholder-gray-400"
                    placeholder="Bedrijf A, Instelling B..." />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Contact Naam -->
                <div class="space-y-2">
                    <label for="contactName" class="block font-heading font-semibold text-kaap-gray text-lg">Contactpersoon (Naam)</label>
                    <input type="text" id="contactName" name="contactName"
                        class="w-full px-5 py-4 rounded-xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-kaap-pink/50 focus:ring-4 focus:ring-kaap-pink/10 outline-none transition-all duration-300 font-medium placeholder-gray-400"
                        placeholder="Voor- en achternaam" />
                </div>

                <!-- Contact Email -->
                <div class="space-y-2">
                    <label for="contactEmail" class="block font-heading font-semibold text-kaap-gray text-lg">Contact (E-mail of URL)</label>
                    <input type="text" id="contactEmail" name="contactEmail"
                        class="w-full px-5 py-4 rounded-xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-kaap-pink/50 focus:ring-4 focus:ring-kaap-pink/10 outline-none transition-all duration-300 font-medium placeholder-gray-400"
                        placeholder="Naam@organisatie.nl" />
                </div>
            </div>

            <!-- Verplichtingen / Subsidies -->
             <div class="space-y-2">
                <label for="obligations" class="block font-heading font-semibold text-kaap-gray text-lg">Verplichtingen (Subsidies/Financiering)</label>
                <p class="text-sm text-kaap-text-gray mb-2">Bijv: "Mede mogelijk gemaakt door...", OPZuid, etc.</p>
                <input type="text" id="obligations" name="obligations"
                    class="w-full px-5 py-4 rounded-xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-kaap-pink/50 focus:ring-4 focus:ring-kaap-pink/10 outline-none transition-all duration-300 font-medium placeholder-gray-400"
                    placeholder="Vermeld hier verplichte logo's of teksten..." />
            </div>

            <!-- Foto's/video's -->
            <div class="space-y-2">
                <label for="mediaLinks" class="block font-heading font-semibold text-kaap-gray text-lg">Foto's / Video's / Bijlagen</label>
                <p class="text-sm text-kaap-text-gray mb-2">Plak hier een link naar bestanden (WeTransfer, Drive, etc.).</p>
                <input type="text" id="mediaLinks" name="mediaLinks"
                    class="w-full px-5 py-4 rounded-xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-kaap-pink/50 focus:ring-4 focus:ring-kaap-pink/10 outline-none transition-all duration-300 font-medium placeholder-gray-400"
                    placeholder="Link naar bestanden..." />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- URL's / Links -->
                <div class="space-y-2">
                    <label for="externalLinks" class="block font-heading font-semibold text-kaap-gray text-lg">Extra Link (Website/LinkedIn)</label>
                    <input type="text" id="externalLinks" name="externalLinks"
                        class="w-full px-5 py-4 rounded-xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-kaap-pink/50 focus:ring-4 focus:ring-kaap-pink/10 outline-none transition-all duration-300 font-medium placeholder-gray-400"
                        placeholder="https://..." />
                </div>

                <!-- Call to Action -->
                <div class="space-y-2">
                    <label for="callToAction" class="block font-heading font-semibold text-kaap-gray text-lg">Call to Action (CTA)</label>
                    <input type="text" id="callToAction" name="callToAction"
                        class="w-full px-5 py-4 rounded-xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-kaap-pink/50 focus:ring-4 focus:ring-kaap-pink/10 outline-none transition-all duration-300 font-medium placeholder-gray-400"
                        placeholder="Bijv: 'Meld je aan', 'Lees meer'" />
                </div>
            </div>

            <div class="pt-4">
                <button type="submit" id="submitBtn"
                    class="group w-full bg-kaap-gray hover:bg-black text-white font-heading font-bold text-lg py-5 rounded-xl shadow-lg hover:shadow-2xl hover:shadow-kaap-pink/20 transform hover:-translate-y-1 transition-all duration-300 flex items-center justify-center gap-2">
                    <span id="submitText">Project Indienen</span>
                    <svg id="submitIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5 group-hover:translate-x-1 transition-transform">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                    </svg>                      
                </button>
            </div>
        </form>
    </div>
</Layout>

<script>
    const form = document.getElementById('submissionForm') as HTMLFormElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const submitText = document.getElementById('submitText');
    const formFeedback = document.getElementById('formFeedback');
    
    // Voice to Text Logic
    const micButton = document.getElementById('micButton');
    const micStatus = document.getElementById('micStatus');
    const descInput = document.getElementById('description') as HTMLTextAreaElement;
    
    if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
        micButton?.classList.remove('hidden');
        // @ts-ignore
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        const recognition = new SpeechRecognition();
        
        recognition.continuous = true;
        recognition.lang = 'nl-NL';
        recognition.interimResults = true;
        
        let isRecording = false;
        let finalTranscript = '';
        let originalText = '';

        recognition.onstart = () => {
            isRecording = true;
            micButton?.classList.add('text-red-500', 'bg-red-50');
            micStatus?.classList.remove('hidden');
            if (descInput) {
                originalText = descInput.value;
                if (originalText && !originalText.endsWith(' ')) originalText += ' ';
            }
            finalTranscript = '';
        };
        
        recognition.onend = () => {
            isRecording = false;
            micButton?.classList.remove('text-red-500', 'bg-red-50');
            micStatus?.classList.add('hidden');
        };
        
        recognition.onresult = (event: any) => {
            let interimTranscript = '';
            for (let i = event.resultIndex; i < event.results.length; ++i) {
                if (event.results[i].isFinal) {
                    finalTranscript += event.results[i][0].transcript;
                } else {
                    interimTranscript += event.results[i][0].transcript;
                }
            }
            if (descInput) {
                descInput.value = originalText + finalTranscript + interimTranscript;
            }
        };
        
        micButton?.addEventListener('click', () => {
            if (isRecording) {
                recognition.stop();
            } else {
                recognition.start();
            }
        });
    }
    
    // Submit Form Logic
    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        if (!submitBtn || !submitText || !formFeedback) return;
        
        // UI Loading state
        submitBtn.disabled = true;
        submitBtn.classList.add('opacity-75', 'cursor-not-allowed');
        submitText.innerText = 'Bezig met opslaan...';
        formFeedback.classList.add('hidden');
        
        const formData = new FormData(form);
        
        try {
            const response = await fetch('/api/submit-project', {
                method: 'POST',
                body: formData
            });
            
            const result = await response.json();
            
            if (result.success) {
                formFeedback.innerText = result.message;
                formFeedback.className = 'p-4 rounded-xl text-center font-semibold mb-4 bg-green-100 text-green-800 transition-all block';
                form.reset();
            } else {
                throw new Error(result.error || 'Er ging iets fout.');
            }
        } catch (error: any) {
            formFeedback.innerText = error.message;
            formFeedback.className = 'p-4 rounded-xl text-center font-semibold mb-4 bg-red-100 text-red-800 transition-all block';
        } finally {
            submitBtn.disabled = false;
            submitBtn.classList.remove('opacity-75', 'cursor-not-allowed');
            submitText.innerText = 'Nieuw Project Aanmelden';
        }
    });
</script>
