---
import Layout from '../layouts/Layout.astro';
---

<Layout title="KAAP Event Aanleveren">
    <div class="space-y-10 reveal active pt-4">
        <div class="max-w-7xl mx-auto">
            <a href="/" class="inline-flex items-center gap-2 text-kaap-text-gray hover:text-kaap-pink font-semibold transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                </svg>
                Terug naar overzicht
            </a>
        </div>
        <div class="text-center space-y-4 -mt-4">
            <div class="inline-block px-4 py-1.5 rounded-full bg-white border border-gray-200 text-sm font-semibold text-orange-500 mb-2 shadow-sm">
                Nieuw Event Aanmelden
            </div>
            <h1 class="text-4xl md:text-5xl font-heading font-bold text-kaap-gray leading-tight">
                Zet jouw event op <span class="text-kaap-gradient">de kaart</span>
            </h1>
            <p class="text-kaap-text-gray text-lg max-w-2xl mx-auto leading-relaxed">
                Geef de details door van het nieuwe innovatie event, zodat we deze kunnen meenemen in de agenda.
            </p>
        </div>

        <form id="eventForm" class="bg-white p-8 md:p-10 rounded-3xl shadow-xl shadow-gray-200/50 border border-gray-100 space-y-8 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1 bg-kaap-gradient"></div>

            <div id="formFeedback" class="hidden p-4 rounded-xl text-center font-semibold mb-4 transition-all"></div>

            <div class="space-y-2">
                <label for="titel" class="block font-heading font-semibold text-kaap-gray text-lg">Event Titel <span class="text-orange-500">*</span></label>
                <input type="text" id="titel" name="titel" required
                    class="w-full px-5 py-4 rounded-xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-orange-500/50 focus:ring-4 focus:ring-orange-500/10 outline-none transition-all duration-300 font-medium placeholder-gray-400"
                    placeholder="Naam van het event" />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-2">
                    <label for="datumTijd" class="block font-heading font-semibold text-kaap-gray text-lg">Datum & Tijd <span class="text-orange-500">*</span></label>
                    <input type="text" id="datumTijd" name="datumTijd" required
                        class="w-full px-5 py-4 rounded-xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-orange-500/50 focus:ring-4 focus:ring-orange-500/10 outline-none transition-all duration-300 font-medium placeholder-gray-400"
                        placeholder="Bijv: 12 Mei 2026, 14:00 - 17:00" />
                </div>
                <div class="space-y-2">
                    <label for="locatie" class="block font-heading font-semibold text-kaap-gray text-lg">Locatie</label>
                    <input type="text" id="locatie" name="locatie"
                        class="w-full px-5 py-4 rounded-xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-orange-500/50 focus:ring-4 focus:ring-orange-500/10 outline-none transition-all duration-300 font-medium placeholder-gray-400"
                        placeholder="Naam van gebouw / adres / online" />
                </div>
            </div>

             <div class="space-y-3">
                <label class="block font-heading font-semibold text-kaap-gray text-lg">Aan welk transitiethema raakt dit event? <span class="text-orange-500">*</span></label>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                     <label class="cursor-pointer relative">
                        <input type="radio" name="transitiethema" value="Water" class="peer sr-only" required>
                        <div class="p-3 rounded-xl bg-gray-50 border-2 border-transparent peer-checked:border-blue-500 peer-checked:bg-blue-50 hover:bg-gray-100 transition-all text-center font-medium text-kaap-gray">
                            💧 Water
                        </div>
                    </label>
                    <label class="cursor-pointer relative">
                        <input type="radio" name="transitiethema" value="Voedsel" class="peer sr-only">
                        <div class="p-3 rounded-xl bg-gray-50 border-2 border-transparent peer-checked:border-green-500 peer-checked:bg-green-50 hover:bg-gray-100 transition-all text-center font-medium text-kaap-gray">
                            🍎 Voedsel
                        </div>
                    </label>
                    <label class="cursor-pointer relative">
                        <input type="radio" name="transitiethema" value="Energie" class="peer sr-only">
                        <div class="p-3 rounded-xl bg-gray-50 border-2 border-transparent peer-checked:border-yellow-500 peer-checked:bg-yellow-50 hover:bg-gray-100 transition-all text-center font-medium text-kaap-gray">
                            ⚡ Energie
                        </div>
                    </label>
                    <label class="cursor-pointer relative">
                        <input type="radio" name="transitiethema" value="Overig" class="peer sr-only">
                        <div class="p-3 rounded-xl bg-gray-50 border-2 border-transparent peer-checked:border-kaap-purple peer-checked:bg-purple-50 hover:bg-gray-100 transition-all text-center font-medium text-kaap-gray">
                            Overig / Algemeen
                        </div>
                    </label>
                </div>
            </div>

            <div class="space-y-2">
                <div class="flex items-center justify-between">
                    <label for="omschrijving" class="block font-heading font-semibold text-kaap-gray text-lg">Korte omschrijving / Programma <span class="text-orange-500">*</span></label>
                    <button type="button" id="micButton" class="text-kaap-gray hover:text-orange-500 transition-colors p-2 rounded-full hover:bg-gray-100 hidden group-focus-within:block" title="Spreek in">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z" />
                        </svg>
                    </button>
                </div>
                 <div class="relative">
                    <textarea id="omschrijving" name="omschrijving" rows="4" required
                        class="w-full px-5 py-4 rounded-xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-orange-500/50 focus:ring-4 focus:ring-orange-500/10 outline-none transition-all duration-300 font-medium placeholder-gray-400 resize-none"
                        placeholder="Typ hier de details over het event en het programma..."></textarea>
                    <div id="micStatus" class="absolute top-2 right-2 hidden">
                        <span class="flex h-3 w-3">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-3 w-3 bg-red-500"></span>
                        </span>
                    </div>
                </div>
            </div>

             <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-2">
                    <label for="inschrijflink" class="block font-heading font-semibold text-kaap-gray text-lg">Inschrijflink (URL)</label>
                    <input type="url" id="inschrijflink" name="inschrijflink"
                        class="w-full px-5 py-4 rounded-xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-orange-500/50 focus:ring-4 focus:ring-orange-500/10 outline-none transition-all duration-300 font-medium placeholder-gray-400"
                        placeholder="https://eventbrite.com/..." />
                </div>
                <div class="space-y-2">
                    <label for="contactPersoon" class="block font-heading font-semibold text-kaap-gray text-lg">Contactpersoon interne info</label>
                    <input type="text" id="contactPersoon" name="contactPersoon"
                        class="w-full px-5 py-4 rounded-xl bg-gray-50 border-2 border-transparent focus:bg-white focus:border-orange-500/50 focus:ring-4 focus:ring-orange-500/10 outline-none transition-all duration-300 font-medium placeholder-gray-400"
                        placeholder="Naam + Email voor interne vragen" />
                </div>
            </div>

            <div class="pt-4">
                <button type="submit" id="submitBtn"
                    class="group w-full bg-kaap-gray hover:bg-black text-white font-heading font-bold text-lg py-5 rounded-xl shadow-lg hover:shadow-2xl hover:shadow-orange-500/20 transform hover:-translate-y-1 transition-all duration-300 flex items-center justify-center gap-2">
                    <span id="submitText">Event Aanmelden</span>
                    <svg id="submitIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5 group-hover:translate-x-1 transition-transform">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
                    </svg>                      
                </button>
            </div>
        </form>
    </div>
</Layout>

<script>
    const form = document.getElementById('eventForm') as HTMLFormElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const submitText = document.getElementById('submitText');
    const formFeedback = document.getElementById('formFeedback');
    const micButton = document.getElementById('micButton');
    const micStatus = document.getElementById('micStatus');
    const omschrijvingInput = document.getElementById('omschrijving') as HTMLTextAreaElement;
    
    // Voice to Text
    if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
        micButton?.classList.remove('hidden');
        // @ts-ignore
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        const recognition = new SpeechRecognition();
        recognition.continuous = true;
        recognition.lang = 'nl-NL';
        recognition.interimResults = true;
        
        let isRecording = false;
        let finalTranscript = '';
        let originalText = '';

        recognition.onstart = () => {
            isRecording = true;
            micButton?.classList.add('text-red-500', 'bg-red-50');
            if (micButton) micButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 7.5A2.25 2.25 0 0 1 7.5 5.25h9a2.25 2.25 0 0 1 2.25 2.25v9a2.25 2.25 0 0 1-2.25 2.25h-9a2.25 2.25 0 0 1-2.25-2.25v-9Z" /></svg>`;
            micStatus?.classList.remove('hidden');
            
            if (omschrijvingInput) {
                originalText = omschrijvingInput.value;
                if (originalText && !originalText.endsWith(' ')) originalText += ' ';
            }
            finalTranscript = '';
        };
        
        recognition.onend = () => {
            isRecording = false;
            micButton?.classList.remove('text-red-500', 'bg-red-50');
            if (micButton) micButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z" /></svg>`;
            micStatus?.classList.add('hidden');
        };
        
        recognition.onresult = (event: any) => {
            let interimTranscript = '';
            for (let i = event.resultIndex; i < event.results.length; ++i) {
                if (event.results[i].isFinal) {
                    finalTranscript += event.results[i][0].transcript;
                } else {
                    interimTranscript += event.results[i][0].transcript;
                }
            }
            if (omschrijvingInput) {
                omschrijvingInput.value = originalText + finalTranscript + interimTranscript;
            }
        };
        
        micButton?.addEventListener('click', () => {
            if (isRecording) {
                recognition.stop();
            } else {
                recognition.start();
            }
        });
    }

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!submitBtn || !submitText || !formFeedback) return;
        
        submitBtn.disabled = true;
        submitBtn.classList.add('opacity-75', 'cursor-not-allowed');
        submitText.innerText = 'Bezig met opslaan...';
        formFeedback.classList.add('hidden');
        
        const formData = new FormData(form);
        
        try {
            const response = await fetch('/api/submit-event', {
                method: 'POST',
                body: formData
            });
            
            const result = await response.json();
            
            if (result.success) {
                formFeedback.innerText = result.message;
                formFeedback.className = 'p-4 rounded-xl text-center font-semibold mb-4 bg-green-100 text-green-800 transition-all block';
                form.reset();
            } else {
                throw new Error(result.error || 'Er ging iets fout bij het verzenden.');
            }
        } catch (error: any) {
            formFeedback.innerText = error.message;
            formFeedback.className = 'p-4 rounded-xl text-center font-semibold mb-4 bg-red-100 text-red-800 transition-all block';
        } finally {
            submitBtn.disabled = false;
            submitBtn.classList.remove('opacity-75', 'cursor-not-allowed');
            submitText.innerText = 'Event Aanmelden';
        }
    });
</script>
